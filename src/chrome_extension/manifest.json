{
  "manifest_version": 3,
  "name": "MCP4ChatGPT Browser Bridge",
  "short_name": "MCP4ChatGPT",
  "version": "1.0.2",
  "description": "Connects Chrome to your local MCP4ChatGPT server, letting ChatGPT read tabs, capture screenshots, navigate pages, and more — while keeping your login sessions intact.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "userScripts",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "MCP4ChatGPT Bridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": []
}
