# MCP4ChatGPT environment configuration
# Copy this file to .env and fill in the values.
#
# Required: set MCP_PUBLIC_BASE_URL to your public HTTPS domain and
# MCP_AUTH_SECRET to a long random string (e.g. `openssl rand -hex 32`).

# ── Public exposure ────────────────────────────────────────────────────────────
# The public HTTPS URL that ChatGPT will connect to. The recommended deployment
# uses Cloudflare Tunnel to route this host to MCP_BIND_HOST:MCP_BIND_PORT.
MCP_PUBLIC_BASE_URL=https://mcp.runzhe.uk

# ── Local listener ─────────────────────────────────────────────────────────────
MCP_BIND_HOST=127.0.0.1
MCP_BIND_PORT=8766

# ── Authentication ─────────────────────────────────────────────────────────────
# Long random secret used both as the OAuth approval password and as the
# HMAC signing key for bearer tokens.
# Generate with: openssl rand -hex 32
MCP_AUTH_SECRET=replace-with-a-long-random-secret

# ── Local file / command / Git access ─────────────────────────────────────────
# Colon-separated list of absolute paths that local_* tools may access.
# Keep this narrow.  Example: /Users/yourname/Projects
MCP_ALLOWED_ROOTS=/Users/yourname/Documents

# ── Terminal bridge (co-te.py) ─────────────────────────────────────────────────
# Absolute path to co-te.py from the codex_work_with_apps project.
# If left unset, the default is ../codex_work_with_apps/co-te.py relative to
# this project directory.
MCP_CO_TE_PATH=

# ── Data and log paths ─────────────────────────────────────────────────────────
# Leave blank to use the defaults inside the project directory.
MCP_DATA_DIR=
MCP_AUDIT_LOG=
# Rotate audit.jsonl by date or when it exceeds this size. Defaults to 20 MB.
MCP_LOG_ROTATE_BYTES=20971520
# Keep compressed log archives for this many days. Defaults to 30.
MCP_LOG_RETENTION_DAYS=30

# ── Firecrawl (web_* tools) ───────────────────────────────────────────────────
# Without an API key, web_* tools remain listed but return web_ops_not_configured.
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# ── Knowledge store ────────────────────────────────────────────────────────────
# Colon-separated roots allowed for adding local knowledge sources.
KNOWLEDGE_ROOTS=/Users/yourname/Documents
# Leave blank to use the default (MCP_DATA_DIR/knowledge).
KNOWLEDGE_STORE_DIR=

# ── TLS (optional; skip if using a reverse proxy for TLS termination) ──────────
TLS_CERT_PATH=
TLS_KEY_PATH=
